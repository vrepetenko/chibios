          </xs:element>
          <xs:element name="default" type="frequencyDefaultType" maxOccurs="1"
            minOccurs="1">
          </xs:element>
        </xs:sequence>
        <xs:element name="select" type="conditionalValueSelectType"
          maxOccurs="1" minOccurs="1">
        </xs:element>
      </xs:choice>
    </xs:complexType>

    <xs:complexType name="conditionalValueSelectType">
      <xs:sequence>
        <xs:element name="when" type="conditionalValueWhenType"
