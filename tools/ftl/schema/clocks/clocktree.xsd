        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="input" use="optional">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1"></xs:minLength>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>

    <xs:complexType name="frequenciesType">
      <xs:choice maxOccurs="1" minOccurs="1">
