<?xml version="1.0" encoding="UTF-8"?>
<xs:schema elementFormDefault="qualified"
  xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <xs:element name="clocktree" type="clocktreeType">
      <xs:key name="clockPointKey">
        <xs:selector xpath="sources/source | clocks/clock"></xs:selector>
        <xs:field xpath="@point"></xs:field>
      </xs:key>
      <xs:key name="stateNameKey">
        <xs:selector xpath="settings/states/state"></xs:selector>
        <xs:field xpath="@name"></xs:field>
      </xs:key>
      <xs:key name="definitionNameKey">
        <xs:selector xpath="settings/definitions/define"></xs:selector>
        <xs:field xpath="@name"></xs:field>
      </xs:key>
      <xs:key name="derivedConfigNameKey">
        <xs:selector xpath="settings/derived-configs/derived-config"></xs:selector>
        <xs:field xpath="@name"></xs:field>
      </xs:key>
      <xs:key name="enumNameKey">
        <xs:selector xpath="settings/enums/enum"></xs:selector>
        <xs:field xpath="@name"></xs:field>
      </xs:key>
      <xs:key name="limitNameKey">
        <xs:selector xpath="settings/limit-set/limit"></xs:selector>
        <xs:field xpath="@name"></xs:field>
      </xs:key>
      <xs:key name="stateValuesStateKey">
        <xs:selector xpath="settings/limit-values/state-values"></xs:selector>
        <xs:field xpath="@state"></xs:field>
      </xs:key>
      <xs:keyref name="stateValuesStateRef" refer="stateNameKey">
        <xs:selector xpath="settings/limit-values/state-values"></xs:selector>
        <xs:field xpath="@state"></xs:field>
      </xs:keyref>
      <xs:keyref name="clockLimitRef" refer="limitNameKey">
        <xs:selector xpath="sources/source/limits | clocks/clock/limits"></xs:selector>
        <xs:field xpath="@ref"></xs:field>
      </xs:keyref>
      <xs:keyref name="stateLimitRef" refer="limitNameKey">
        <xs:selector xpath="settings/limit-values/state-values/limit"></xs:selector>
        <xs:field xpath="@name"></xs:field>
      </xs:keyref>
      <xs:keyref name="sinkInputRef" refer="clockPointKey">
        <xs:selector xpath="sinks/sink"></xs:selector>
        <xs:field xpath="@input"></xs:field>
      </xs:keyref>
      <xs:keyref name="sinkLimitRef" refer="limitNameKey">
        <xs:selector xpath="sinks/sink/limits"></xs:selector>
        <xs:field xpath="@ref"></xs:field>
      </xs:keyref>
    </xs:element>
    
    <xs:complexType name="clocktreeType">
      <xs:sequence>
            <xs:element name="settings" type="settingsType" maxOccurs="1" minOccurs="1"></xs:element>
        <xs:element name="sources" type="sourcesType" maxOccurs="1"
          minOccurs="0">
        </xs:element>
            <xs:element name="clocks" type="clocksType" maxOccurs="1"
          minOccurs="1">
        </xs:element>
        <xs:element name="sinks" type="sinksType" maxOccurs="1"
          minOccurs="0">
        </xs:element>
      </xs:sequence>
    </xs:complexType>

    <xs:complexType name="sourcesType">
      <xs:sequence>
        <xs:element name="source" type="sourcePointType" maxOccurs="unbounded"
          minOccurs="1">
        </xs:element>
      </xs:sequence>
    </xs:complexType>

    <xs:complexType name="clocksType">
      <xs:sequence>
        <xs:element name="clock" type="clockType" maxOccurs="unbounded" minOccurs="1"></xs:element>
      </xs:sequence>
    </xs:complexType>

    <xs:complexType name="sinksType">
      <xs:sequence>
        <xs:element name="sink" type="sinkType" maxOccurs="unbounded"
          minOccurs="1">
        </xs:element>
      </xs:sequence>
    </xs:complexType>

    <xs:complexType name="sinkType">
      <xs:sequence>
        <xs:element name="description" type="xs:string" maxOccurs="1"
          minOccurs="0">
        </xs:element>
        <xs:element name="limits" type="clockLimitType" maxOccurs="1"
          minOccurs="0">
        </xs:element>
      </xs:sequence>
      <xs:attribute name="name" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1"></xs:minLength>
            <xs:whiteSpace value="collapse"></xs:whiteSpace>
            <xs:pattern value="[A-Za-z_][A-Za-z0-9_]*"></xs:pattern>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="input" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1"></xs:minLength>
            <xs:whiteSpace value="collapse"></xs:whiteSpace>
            <xs:pattern value="[A-Za-z_][A-Za-z0-9_]*"></xs:pattern>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="condition" use="optional">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1"></xs:minLength>
            <xs:whiteSpace value="collapse"></xs:whiteSpace>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
    

    <xs:complexType name="sourcePointType">
      <xs:sequence>
        <xs:element name="description" type="xs:string" maxOccurs="1"
          minOccurs="1">
        </xs:element>
        <xs:element name="bits" type="boolBitsType" maxOccurs="unbounded"
          minOccurs="0">
        </xs:element>
        <xs:element name="limits" type="clockLimitType" maxOccurs="1"
          minOccurs="0">
        </xs:element>
        <xs:element name="frequencies" type="frequenciesType" maxOccurs="1"
          minOccurs="0">
        </xs:element>
      </xs:sequence>
      <xs:attribute name="point" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1"></xs:minLength>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="enable" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="always"></xs:enumeration>
            <xs:enumeration value="manual"></xs:enumeration>
            <xs:enumeration value="auto"></xs:enumeration>
            <xs:enumeration value="never"></xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="default" use="optional">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="TRUE"></xs:enumeration>
            <xs:enumeration value="FALSE"></xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="dynamic" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="yes"></xs:enumeration>
            <xs:enumeration value="no"></xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="private" use="optional" default="false">
        <xs:annotation>
          <xs:documentation>
            Clock point is internal to the generated clock tree and is not
            exported as a public runtime clock point.
          </xs:documentation>
        </xs:annotation>
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:enumeration value="true"></xs:enumeration>
            <xs:enumeration value="false"></xs:enumeration>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="frequency" use="optional">
        <xs:simpleType>
          <xs:restriction base="xs:string">
            <xs:minLength value="1"></xs:minLength>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>

    <xs:complexType name="clockType">
      <xs:sequence>
        <xs:element name="description" type="xs:string" maxOccurs="1"
          minOccurs="1">
        </xs:element>
        <xs:element name="bits" type="boolBitsType" maxOccurs="unbounded"
          minOccurs="0">
        </xs:element>
        <xs:element name="limits" type="clockLimitType" maxOccurs="1"
          minOccurs="0">
        </xs:element>
        <xs:choice maxOccurs="1" minOccurs="1">
          <xs:element name="derived" type="derivedType" maxOccurs="1"
