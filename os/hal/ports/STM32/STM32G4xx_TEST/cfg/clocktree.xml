<clocktree
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="http://www.chibios.org/xml/schema/clocks/clocktree.xsd">
  <settings>
    <prefixes clock_points="CLK_" macros="STM32_" cfgs="STM32_CFG_" />
    <suffixes frequency="_FREQ" clock="_CLOCK" values="_VALUE" bits="_BITS"
              selector="_SEL" enable="_ENABLE" enabled="_ENABLED" />
    <enums>
      <enum name="PWR_CR1_VOS" field="PWR_CR1_VOS_Pos">
        <item name="RANGE1" value="1U" />
        <item name="RANGE2" value="2U" />
      </enum>
    </enums>
    <definitions>
      <define name="RCC_PLLCFGR_PLLSRC_NOCLOCK" value="0U" />
      <define name="RCC_BDCR_LSCOSEL_NOCLOCK" value="0U" />
      <define name="RCC_BDCR_LSCOSEL_LSI" value="RCC_BDCR_LSCOEN" />
      <define name="RCC_BDCR_LSCOSEL_LSE" value="(RCC_BDCR_LSCOEN | RCC_BDCR_LSCOSEL)" />
    </definitions>
    <configs>
      <config name="CLOCK_DYNAMIC" type="bool" default="FALSE"
              role="dynamic_mode">
        <description>Enables dynamic clock handling.</description>
      </config>
      <config name="PWR_VOS" type="set" default="PWR_CR1_VOS_RANGE1"
              values="PWR_CR1_VOS_RANGE1 PWR_CR1_VOS_RANGE2">
        <description>Selects the core voltage scaling range.</description>
      </config>
      <config name="PWR_BOOST" type="bool" default="TRUE">
        <description>Enables the power boost mode.</description>
      </config>
    </configs>
    <states>
      <state name="boost"
             when="(STM32_CFG_PWR_VOS == PWR_CR1_VOS_RANGE1) &amp;&amp; (STM32_CFG_PWR_BOOST == TRUE)" />
      <state name="vos1"
             when="STM32_CFG_PWR_VOS == PWR_CR1_VOS_RANGE1" />
      <state name="vos2"
             when="STM32_CFG_PWR_VOS == PWR_CR1_VOS_RANGE2" />
    </states>
    <limit-set>
      <limit name="HSECLK" min="yes" max="yes" />
      <limit name="LSECLK" min="yes" max="yes" />
      <limit name="PLLIN" min="yes" max="yes" />
      <limit name="PLLVCO" min="yes" max="yes" />
      <limit name="PLLP" min="yes" max="yes" />
      <limit name="PLLQ" min="yes" max="yes" />
      <limit name="PLLR" min="yes" max="yes" />
      <limit name="SYSCLK" min="no" max="yes" />
      <limit name="HCLK" min="no" max="yes" />
      <limit name="PCLK1" min="no" max="yes" />
      <limit name="PCLK2" min="no" max="yes" />
      <limit name="ADCCLK" min="no" max="yes" />
      <limit name="FLASH_0WS" min="no" max="yes" />
      <limit name="FLASH_1WS" min="no" max="yes" />
      <limit name="FLASH_2WS" min="no" max="yes" />
      <limit name="FLASH_3WS" min="no" max="yes" />
      <limit name="FLASH_4WS" min="no" max="yes" />
    </limit-set>
    <limit-values>
      <state-values state="boost">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="8000000" max="48000000" />
          <default min="8000000" max="48000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="32768" max="1000000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="2660000" max="16000000" />
        <limit name="PLLVCO" min="96000000" max="344000000" />
        <limit name="PLLP" min="2064500" max="170000000" />
        <limit name="PLLQ" min="8000000" max="170000000" />
        <limit name="PLLR" min="8000000" max="170000000" />
        <limit name="SYSCLK" max="170000000" />
        <limit name="HCLK" max="170000000" />
        <limit name="PCLK1" max="170000000" />
        <limit name="PCLK2" max="170000000" />
        <limit name="ADCCLK" max="60000000" />
        <limit name="FLASH_0WS" max="34000000" />
        <limit name="FLASH_1WS" max="68000000" />
        <limit name="FLASH_2WS" max="102000000" />
        <limit name="FLASH_3WS" max="136000000" />
        <limit name="FLASH_4WS" max="170000000" />
      </state-values>
      <state-values state="vos1">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="8000000" max="48000000" />
          <default min="8000000" max="48000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="32768" max="1000000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="2660000" max="16000000" />
        <limit name="PLLVCO" min="96000000" max="344000000" />
        <limit name="PLLP" min="2064500" max="150000000" />
        <limit name="PLLQ" min="8000000" max="150000000" />
        <limit name="PLLR" min="8000000" max="150000000" />
        <limit name="SYSCLK" max="150000000" />
        <limit name="HCLK" max="150000000" />
        <limit name="PCLK1" max="150000000" />
        <limit name="PCLK2" max="150000000" />
        <limit name="ADCCLK" max="60000000" />
        <limit name="FLASH_0WS" max="30000000" />
        <limit name="FLASH_1WS" max="60000000" />
        <limit name="FLASH_2WS" max="90000000" />
        <limit name="FLASH_3WS" max="120000000" />
        <limit name="FLASH_4WS" max="150000000" />
      </state-values>
      <state-values state="vos2">
        <limit name="HSECLK">
          <case when="defined(STM32_HSE_BYPASS)" min="8000000" max="26000000" />
          <default min="8000000" max="26000000" />
        </limit>
        <limit name="LSECLK">
          <case when="defined(STM32_LSE_BYPASS)" min="32768" max="1000000" />
          <default min="32768" max="32768" />
        </limit>
        <limit name="PLLIN" min="2660000" max="16000000" />
        <limit name="PLLVCO" min="96000000" max="128000000" />
        <limit name="PLLP" min="2064500" max="26000000" />
        <limit name="PLLQ" min="8000000" max="26000000" />
        <limit name="PLLR" min="8000000" max="26000000" />
        <limit name="SYSCLK" max="26000000" />
        <limit name="HCLK" max="26000000" />
        <limit name="PCLK1" max="26000000" />
        <limit name="PCLK2" max="26000000" />
        <limit name="ADCCLK" max="26000000" />
        <limit name="FLASH_0WS" max="12000000" />
        <limit name="FLASH_1WS" max="24000000" />
        <limit name="FLASH_2WS" max="26000000" />
        <limit name="FLASH_3WS" max="0" />
        <limit name="FLASH_4WS" max="0" />
      </state-values>
    </limit-values>
  </settings>
  <sources>
    <source point="NONE" enable="never" dynamic="no" frequency="0U">
      <description>pseudo-clock for disabled sources</description>
    </source>
    <source point="HSI16" enable="manual" dynamic="yes" frequency="16000000U">
      <description>16MHz high speed internal oscillator</description>
      <bits enabled="(RCC_CR_HSIKERON | RCC_CR_HSION)" disabled="0U" />
    </source>
    <source point="HSI48" enable="manual" dynamic="yes" frequency="48000000U">
      <description>48MHz high speed internal oscillator</description>
      <bits enabled="RCC_CRRCR_HSI48ON" disabled="0U" />
    </source>
    <source point="HSE" enable="manual" dynamic="yes" frequency="STM32_HSECLK">
      <description>high frequency external oscillator</description>
      <bits enabled="RCC_CR_HSEON" disabled="0U" />
      <limits ref="HSECLK" />
    </source>
    <source point="LSE" enable="manual" dynamic="no" frequency="STM32_LSECLK">
      <description>low frequency external oscillator</description>
      <bits enabled="RCC_BDCR_LSEON" disabled="0U" />
      <limits ref="LSECLK" />
    </source>
    <source point="LSI" enable="manual" dynamic="no" frequency="32000U">
      <description>low frequency internal oscillator</description>
      <bits enabled="RCC_CSR_LSION" disabled="0U" />
    </source>
    <source point="CKIN" enable="always" dynamic="no" frequency="0U">
      <description>external audio clock input</description>
    </source>
  </sources>
  <clocks>
    <clock point="PLLIN" enable="auto" dynamic="yes" private="true">
      <description>PLL input</description>
      <mux name="PLLSRC">
        <input point="NONE">
          <bits value="RCC_PLLCFGR_PLLSRC_NOCLOCK" />
        </input>
        <input point="HSI16" default="yes">
          <bits value="RCC_PLLCFGR_PLLSRC_HSI" />
        </input>
        <input point="HSE">
          <bits value="RCC_PLLCFGR_PLLSRC_HSE" />
        </input>
      </mux>
    </clock>
    <clock point="PLLREF" enable="auto" dynamic="yes" private="true">
      <description>PLL reference</description>
      <limits ref="PLLIN" />
      <divider name="PLLM" input="PLLIN">
        <value min="1" max="16" default="4">
          <bits value="((%N% - 1U) &lt;&lt; RCC_PLLCFGR_PLLM_Pos)" />
        </value>
      </divider>
    </clock>
     <clock point="PLLVCO" enable="auto" dynamic="yes" private="true">
      <description>PLL VCO</description>
      <limits ref="PLLVCO" />
      <multiplier name="PLLN" input="PLLREF">
        <value min="8" max="127" default="84">
          <bits value="(%N% &lt;&lt; RCC_PLLCFGR_PLLN_Pos)" />
        </value>
      </multiplier>
    </clock>
     <clock point="PLLP" enable="auto" dynamic="yes">
      <description>PLL P output</description>
      <bits enabled="RCC_PLLCFGR_PLLPEN" disabled="0U" />
      <limits ref="PLLP" />
      <divider name="PLLP" input="PLLVCO">
        <value min="2" max="31" default="7">
          <bits value="(%N% &lt;&lt; RCC_PLLCFGR_PLLPDIV_Pos)" />
        </value>
      </divider>
    </clock>
    <clock point="PLLQ" enable="auto" dynamic="yes">
      <description>PLL Q output</description>
      <bits enabled="RCC_PLLCFGR_PLLQEN" disabled="0U" />
      <limits ref="PLLQ" />
      <divider name="PLLQ" input="PLLVCO">
        <set values="2 4 6 8" default="8">
          <bits value="(((%N% / 2U) - 1U) &lt;&lt; RCC_PLLCFGR_PLLQ_Pos)" />
        </set>
      </divider>
    </clock>
    <clock point="PLLR" enable="auto" dynamic="yes">
     <description>PLL R output</description>
      <bits enabled="RCC_PLLCFGR_PLLREN" disabled="0U" />
      <limits ref="PLLR" />
      <divider name="PLLR" input="PLLVCO">
        <set values="2 4 6 8" default="2">
          <bits value="(((%N% / 2U) - 1U) &lt;&lt; RCC_PLLCFGR_PLLR_Pos)" />
        </set>
      </divider>
    </clock>
    <clock point="SYSCLK" enable="always" dynamic="yes">
      <description>system clock</description>
      <limits ref="SYSCLK" />
      <mux name="SW">
        <input point="HSI16">
          <bits value="RCC_CFGR_SW_HSI" />
        </input>
        <input point="HSE">
          <bits value="RCC_CFGR_SW_HSE" />
        </input>
        <input point="PLLR" label="PLLRCLK" default="yes">
          <bits value="RCC_CFGR_SW_PLL" />
        </input>
      </mux>
    </clock>
    <clock point="HCLK" enable="always" dynamic="yes">
      <description>AHB</description>
      <limits ref="HCLK" />
      <divider name="HPRE" input="SYSCLK">
        <choices>
          <choice item="DIV1" value="1">
            <bits value="RCC_CFGR_HPRE_DIV1" />
          </choice>
          <choice item="DIV2" value="2">
            <bits value="RCC_CFGR_HPRE_DIV2" />
          </choice>
          <choice item="DIV4" value="4">
            <bits value="RCC_CFGR_HPRE_DIV4" />
          </choice>
          <choice item="DIV8" value="8">
            <bits value="RCC_CFGR_HPRE_DIV8" />
          </choice>
          <choice item="DIV16" value="16">
            <bits value="RCC_CFGR_HPRE_DIV16" />
          </choice>
          <choice item="DIV64" value="64">
            <bits value="RCC_CFGR_HPRE_DIV64" />
          </choice>
          <choice item="DIV128" value="128">
            <bits value="RCC_CFGR_HPRE_DIV128" />
          </choice>
          <choice item="DIV256" value="256">
            <bits value="RCC_CFGR_HPRE_DIV256" />
          </choice>
          <choice item="DIV512" value="512">
            <bits value="RCC_CFGR_HPRE_DIV512" />
          </choice>
        </choices>
      </divider>
    </clock>
    <clock point="PCLK1" enable="always" dynamic="yes">
     <description>APB1</description>
      <limits ref="PCLK1" />
      <divider name="PPRE1" input="HCLK">
        <choices default="2">
          <choice item="DIV1" value="1">
            <bits value="RCC_CFGR_PPRE1_DIV1" />
          </choice>
          <choice item="DIV2" value="2">
            <bits value="RCC_CFGR_PPRE1_DIV2" />
          </choice>
          <choice item="DIV4" value="4">
            <bits value="RCC_CFGR_PPRE1_DIV4" />
          </choice>
          <choice item="DIV8" value="8">
            <bits value="RCC_CFGR_PPRE1_DIV8" />
          </choice>
          <choice item="DIV16" value="16">
            <bits value="RCC_CFGR_PPRE1_DIV16" />
          </choice>
        </choices>
      </divider>
    </clock>
    <clock point="PCLK2" enable="always" dynamic="yes">
     <description>APB2</description>
      <limits ref="PCLK2" />
      <divider name="PPRE2" input="HCLK">
        <choices>
          <choice item="DIV1" value="1">
            <bits value="RCC_CFGR_PPRE2_DIV1" />
          </choice>
          <choice item="DIV2" value="2">
            <bits value="RCC_CFGR_PPRE2_DIV2" />
          </choice>
          <choice item="DIV4" value="4">
            <bits value="RCC_CFGR_PPRE2_DIV4" />
          </choice>
          <choice item="DIV8" value="8">
            <bits value="RCC_CFGR_PPRE2_DIV8" />
          </choice>
          <choice item="DIV16" value="16">
            <bits value="RCC_CFGR_PPRE2_DIV16" />
          </choice>
        </choices>
      </divider>
    </clock>
    <clock point="PCLK1TIM" enable="always" dynamic="yes">
      <description>APB1 timer clock</description>
      <derived input="PCLK1" frequency="((STM32_CFG_PCLK1_VALUE == 1) ? %I% : (%I% * 2U))" />
    </clock>
    <clock point="PCLK2TIM" enable="always" dynamic="yes">
      <description>APB2 timer clock</description>
      <derived input="PCLK2" frequency="((STM32_CFG_PCLK2_VALUE == 1) ? %I% : (%I% * 2U))" />
    </clock>
    <clock point="HSEDIV" enable="auto" dynamic="no">
      <description>HSE divided-by-32 RTC clock</description>
      <!-- STM32G4 has no programmable RTCPRE field, this is a fixed divider. -->
      <derived input="HSE" frequency="(%I% / 32U)" />
    </clock>
    <clock point="MCODIV" enable="always" dynamic="no">
      <description>MCO source before prescaler</description>
      <mux name="MCOSEL" field="RCC_CFGR_MCOSEL" offset="24U">
        <input point="NONE" label="NOCLOCK" encoding="0U" default="yes" />
        <input point="SYSCLK" encoding="1U" />
        <input point="HSI16" encoding="3U" />
        <input point="HSE" encoding="4U" />
        <input point="PLLR" label="PLLRCLK" encoding="5U" />
        <input point="LSI" encoding="6U" />
        <input point="LSE" encoding="7U" />
        <input point="HSI48" encoding="8U" />
      </mux>
    </clock>
    <clock point="MCO" enable="always" dynamic="yes">
      <description>MCO output pin</description>
      <divider name="MCOPRE" input="MCODIV">
        <choices>
          <choice item="DIV1" value="1">
            <bits value="RCC_CFGR_MCOPRE_DIV1" />
          </choice>
          <choice item="DIV2" value="2">
            <bits value="RCC_CFGR_MCOPRE_DIV2" />
          </choice>
          <choice item="DIV4" value="4">
            <bits value="RCC_CFGR_MCOPRE_DIV4" />
          </choice>
          <choice item="DIV8" value="8">
            <bits value="RCC_CFGR_MCOPRE_DIV8" />
          </choice>
          <choice item="DIV16" value="16">
            <bits value="RCC_CFGR_MCOPRE_DIV16" />
          </choice>
        </choices>
      </divider>
    </clock>
    <clock point="LSCO" enable="always" dynamic="no">
      <description>LSCO output pin</description>
      <mux name="LSCOSEL">
        <input point="NONE" label="NOCLOCK" default="yes">
          <bits value="RCC_BDCR_LSCOSEL_NOCLOCK" />
        </input>
        <input point="LSI">
          <bits value="RCC_BDCR_LSCOSEL_LSI" />
        </input>
        <input point="LSE">
          <bits value="RCC_BDCR_LSCOSEL_LSE" />
        </input>
      </mux>
    </clock>
    <clock point="RTC" enable="auto" dynamic="no">
      <description>RTC</description>
      <mux name="RTCSEL" field="RCC_BDCR_RTCSEL" offset="8U">
        <input point="NONE" label="NOCLOCK" encoding="0U" default="yes" />
        <input point="LSE" encoding="1U" />
        <input point="LSI" encoding="2U" />
        <input point="HSEDIV" encoding="3U" />
      </mux>
    </clock>
    <clock point="USART1" enable="always" dynamic="no">
      <description>USART1</description>
      <mux name="USART1SEL" field="RCC_CCIPR_USART1SEL" offset="0U">
        <input point="PCLK2" encoding="0U" />
        <input point="SYSCLK" encoding="1U" default="yes" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="USART2" enable="always" dynamic="no">
      <description>USART2</description>
      <mux name="USART2SEL" field="RCC_CCIPR_USART2SEL" offset="2U">
        <input point="PCLK1" encoding="0U" />
        <input point="SYSCLK" encoding="1U" default="yes" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="USART3" enable="always" dynamic="no">
      <description>USART3</description>
      <mux name="USART3SEL" field="RCC_CCIPR_USART3SEL" offset="4U">
        <input point="PCLK1" encoding="0U" />
        <input point="SYSCLK" encoding="1U" default="yes" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="UART4" enable="always" dynamic="no">
      <description>UART4</description>
      <mux name="UART4SEL" field="RCC_CCIPR_UART4SEL" offset="6U">
        <input point="PCLK1" encoding="0U" />
        <input point="SYSCLK" encoding="1U" default="yes" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="UART5" enable="always" dynamic="no">
      <description>UART5</description>
      <mux name="UART5SEL" field="RCC_CCIPR_UART5SEL" offset="8U">
        <input point="PCLK1" encoding="0U" />
        <input point="SYSCLK" encoding="1U" default="yes" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="LPUART1" enable="always" dynamic="no">
      <description>LPUART1</description>
      <mux name="LPUART1SEL" field="RCC_CCIPR_LPUART1SEL" offset="10U">
        <input point="PCLK1" encoding="0U" />
        <input point="SYSCLK" encoding="1U" default="yes" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="I2C1" enable="always" dynamic="no">
      <description>I2C1</description>
      <mux name="I2C1SEL" field="RCC_CCIPR_I2C1SEL" offset="12U">
        <input point="PCLK1" encoding="0U" default="yes" />
        <input point="SYSCLK" encoding="1U" />
        <input point="HSI16" encoding="2U" />
      </mux>
    </clock>
    <clock point="I2C2" enable="always" dynamic="no">
      <description>I2C2</description>
      <mux name="I2C2SEL" field="RCC_CCIPR_I2C2SEL" offset="14U">
        <input point="PCLK1" encoding="0U" default="yes" />
        <input point="SYSCLK" encoding="1U" />
        <input point="HSI16" encoding="2U" />
      </mux>
    </clock>
    <clock point="I2C3" enable="always" dynamic="no">
      <description>I2C3</description>
      <mux name="I2C3SEL" field="RCC_CCIPR_I2C3SEL" offset="16U">
        <input point="PCLK1" encoding="0U" default="yes" />
        <input point="SYSCLK" encoding="1U" />
        <input point="HSI16" encoding="2U" />
      </mux>
    </clock>
    <clock point="I2C4" enable="always" dynamic="no">
      <description>I2C4</description>
      <mux name="I2C4SEL" field="RCC_CCIPR2_I2C4SEL" offset="0U">
        <input point="PCLK1" encoding="0U" default="yes" />
        <input point="SYSCLK" encoding="1U" />
        <input point="HSI16" encoding="2U" />
      </mux>
    </clock>
    <clock point="LPTIM1" enable="always" dynamic="no">
      <description>LPTIM1</description>
      <mux name="LPTIM1SEL" field="RCC_CCIPR_LPTIM1SEL" offset="18U">
        <input point="PCLK1" encoding="0U" default="yes" />
        <input point="LSI" encoding="1U" />
        <input point="HSI16" encoding="2U" />
        <input point="LSE" encoding="3U" />
      </mux>
    </clock>
    <clock point="SAI1" enable="always" dynamic="no">
      <description>SAI1</description>
      <mux name="SAI1SEL" field="RCC_CCIPR_SAI1SEL" offset="20U">
        <input point="SYSCLK" encoding="0U" default="yes" />
        <input point="PLLQ" label="PLLQCLK" encoding="1U" />
        <input point="CKIN" encoding="2U" />
        <input point="HSI16" encoding="3U" />
      </mux>
    </clock>
    <clock point="I2S23" enable="always" dynamic="no">
      <description>I2S23</description>
      <mux name="I2S23SEL" field="RCC_CCIPR_I2S23SEL" offset="22U">
        <input point="SYSCLK" encoding="0U" default="yes" />
        <input point="PLLQ" label="PLLQCLK" encoding="1U" />
        <input point="CKIN" encoding="2U" />
        <input point="HSI16" encoding="3U" />
      </mux>
    </clock>
    <clock point="FDCAN" enable="always" dynamic="no">
      <description>FDCAN</description>
      <mux name="FDCANSEL" field="RCC_CCIPR_FDCANSEL" offset="24U">
        <input point="HSE" encoding="0U" default="yes" />
        <input point="PLLQ" label="PLLQCLK" encoding="1U" />
        <input point="PCLK1" encoding="2U" />
      </mux>
    </clock>
    <clock point="CLK48" enable="always" dynamic="no">
      <description>48MHz clock</description>
      <mux name="CLK48SEL" field="RCC_CCIPR_CLK48SEL" offset="26U">
        <input point="HSI48" encoding="0U" default="yes" />
        <input point="PLLQ" label="PLLQCLK" encoding="2U" />
      </mux>
    </clock>
    <clock point="ADC12" enable="always" dynamic="no">
      <description>ADC12</description>
      <limits ref="ADCCLK" />
      <mux name="ADC12SEL" field="RCC_CCIPR_ADC12SEL" offset="28U">
        <input point="NONE" label="NOCLK" encoding="0U" />
        <input point="PLLP" label="PLLPCLK" encoding="1U" default="yes" />
        <input point="SYSCLK" encoding="2U" />
      </mux>
    </clock>
