<?xml version="1.0" encoding="UTF-8"?>
<module xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="http://www.chibios.org/xml/schema/ccode/modules.xsd"
  name="lis302dl" descr="LIS302DL Driver" sourcepath="devices/ST"
  headerpath="devices/ST" editcode="true">
  <brief>LIS302DL accelerometer chip driver.</brief>
  <imports>
    <import>hal_base_driver.xml</import>
    <import>hal_accelerometer.xml</import>
  </imports>
  <public>
    <includes>
      <include style="regular">hal.h</include>
      <include style="regular">hal_accelerometer.h</include>
    </includes>
    <definitions_early>
      <group description="Version identification">
        <define name="LIS302DL_VERSION" value="&quot;2.0.0&quot;">
          <brief>LIS302DL driver version string.</brief>
        </define>
        <define name="LIS302DL_MAJOR" value="2">
          <brief>LIS302DL driver version major number.</brief>
        </define>
        <define name="LIS302DL_MINOR" value="0">
          <brief>LIS302DL driver version minor number.</brief>
        </define>
        <define name="LIS302DL_PATCH" value="0">
          <brief>LIS302DL driver version patch number.</brief>
        </define>
      </group>
      <group description="LIS302DL accelerometer characteristics">
        <define name="LIS302DL_ACC_NUMBER_OF_AXES" value="3U" />
        <define name="LIS302DL_ACC_2G" value="2.0f" />
        <define name="LIS302DL_ACC_8G" value="8.0f" />
        <define name="LIS302DL_ACC_SENS_2G" value="18.0f" />
        <define name="LIS302DL_ACC_SENS_8G" value="72.0f" />
        <define name="LIS302DL_ACC_BIAS" value="0.0f" />
      </group>
      <group description="LIS302DL SPI command bits">
        <define name="LIS302DL_MS" value="(1U &lt;&lt; 6)" />
        <define name="LIS302DL_RW" value="(1U &lt;&lt; 7)" />
      </group>
      <group description="LIS302DL register addresses">
        <define name="LIS302DL_AD_WHO_AM_I" value="0x0FU" />
        <define name="LIS302DL_AD_CTRL_REG1" value="0x20U" />
        <define name="LIS302DL_AD_CTRL_REG2" value="0x21U" />
        <define name="LIS302DL_AD_CTRL_REG3" value="0x22U" />
        <define name="LIS302DL_AD_STATUS_REG" value="0x27U" />
        <define name="LIS302DL_AD_OUT_X" value="0x29U" />
        <define name="LIS302DL_AD_OUT_Y" value="0x2BU" />
        <define name="LIS302DL_AD_OUT_Z" value="0x2DU" />
      </group>
      <group description="LIS302DL CTRL_REG1 register bits">
        <define name="LIS302DL_CTRL_REG1_XEN" value="(1U &lt;&lt; 0)" />
        <define name="LIS302DL_CTRL_REG1_YEN" value="(1U &lt;&lt; 1)" />
        <define name="LIS302DL_CTRL_REG1_ZEN" value="(1U &lt;&lt; 2)" />
        <define name="LIS302DL_CTRL_REG1_FS_MASK" value="0x20U" />
        <define name="LIS302DL_CTRL_REG1_PD" value="(1U &lt;&lt; 6)" />
      </group>
      <group description="LIS302DL CTRL_REG2 register bits">
        <define name="LIS302DL_CTRL_REG2_HPCF1" value="(1U &lt;&lt; 0)" />
        <define name="LIS302DL_CTRL_REG2_HPCF2" value="(1U &lt;&lt; 1)" />
        <define name="LIS302DL_CTRL_REG2_HPFFWU1" value="(1U &lt;&lt; 2)" />
        <define name="LIS302DL_CTRL_REG2_HPFFWU2" value="(1U &lt;&lt; 3)" />
        <define name="LIS302DL_CTRL_REG2_FDS" value="(1U &lt;&lt; 4)" />
      </group>
    </definitions_early>
    <configs>
      <config name="LIS302DL_SHARED_SPI" default="FALSE">
        <brief>Enables SPI bus locking around LIS302DL transactions.</brief>
        <assert invalid="($N != FALSE) &amp;&amp; ($N != TRUE)" />
      </config>
      <config name="LIS302DL_USE_ADVANCED" default="FALSE">
        <brief>Enables advanced LIS302DL configuration fields.</brief>
        <assert invalid="($N != FALSE) &amp;&amp; ($N != TRUE)" />
      </config>
    </configs>
    <definitions_late>
      <verbatim><![CDATA[
#if !defined(__CHIBIOS_XHAL_CONF__)
#error "LIS302DL chip driver requires XHAL"
#endif

#if HAL_USE_SPI != TRUE
#error "LIS302DL requires HAL_USE_SPI"
#endif

#if SPI_USE_SYNCHRONIZATION != TRUE
#error "LIS302DL requires SPI_USE_SYNCHRONIZATION"
#endif

#if (LIS302DL_SHARED_SPI == TRUE) && (HAL_USE_MUTUAL_EXCLUSION != TRUE)
#error "LIS302DL_SHARED_SPI requires HAL_USE_MUTUAL_EXCLUSION"
#endif]]></verbatim>
      <group description="LIS302DL accelerometer method aliases">
        <define name="lis302dlAccelerometerGetAxesNumber"
          value="halAccelerometerGetAxesNumber(&amp;((devp)-&gt;accelerometer))">
          <param name="devp" />
        </define>
        <define name="lis302dlAccelerometerReadRaw"
          value="halAccelerometerReadRaw(&amp;((devp)-&gt;accelerometer), axes)">
          <param name="devp" />
          <param name="axes" />
        </define>
        <define name="lis302dlAccelerometerReadCooked"
          value="halAccelerometerReadCooked(&amp;((devp)-&gt;accelerometer), axes)">
          <param name="devp" />
          <param name="axes" />
        </define>
        <define name="lis302dlAccelerometerSetBias"
          value="halAccelerometerSetBias(&amp;((devp)-&gt;accelerometer), biases)">
          <param name="devp" />
          <param name="biases" />
        </define>
        <define name="lis302dlAccelerometerResetBias"
          value="halAccelerometerResetBias(&amp;((devp)-&gt;accelerometer))">
          <param name="devp" />
        </define>
        <define name="lis302dlAccelerometerSetSensitivity"
          value="halAccelerometerSetSensitivity(&amp;((devp)-&gt;accelerometer), sensitivities)">
          <param name="devp" />
          <param name="sensitivities" />
        </define>
        <define name="lis302dlAccelerometerResetSensitivity"
          value="halAccelerometerResetSensitivity(&amp;((devp)-&gt;accelerometer))">
          <param name="devp" />
        </define>
        <define name="lis302dlAccelerometerSetFullScale"
          value="lis302dlSetFullScale(devp, fs)">
          <param name="devp" />
          <param name="fs" />
        </define>
      </group>
    </definitions_late>
    <types>
      <typedef name="lis302dl_config_t">
        <basetype ctype="struct lis302dl_config" />
      </typedef>
      <verbatim><![CDATA[
typedef enum {
  LIS302DL_ACC_FS_2G = 0x00U,
  LIS302DL_ACC_FS_8G = 0x20U
} lis302dl_acc_fs_t;

typedef enum {
  LIS302DL_ACC_ODR_100HZ = 0x00U,
  LIS302DL_ACC_ODR_400HZ = 0x80U
} lis302dl_acc_odr_t;

typedef enum {
  LIS302DL_ACC_HP_DISABLED = 0x00U,
  LIS302DL_ACC_HP_0        = 0x10U,
  LIS302DL_ACC_HP_1        = 0x11U,
  LIS302DL_ACC_HP_2        = 0x12U,
  LIS302DL_ACC_HP_3        = 0x13U
} lis302dl_acc_hp_t;

struct lis302dl_config {
  hal_spi_driver_c          *spip;
  const hal_spi_config_t    *spicfg;
  const float               *accsensitivity;
  const float               *accbias;
  lis302dl_acc_fs_t         accfullscale;
  lis302dl_acc_odr_t        accodr;
#if LIS302DL_USE_ADVANCED == TRUE
  lis302dl_acc_hp_t         acchighpass;
#endif
};]]></verbatim>
